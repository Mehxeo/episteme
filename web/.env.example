# Browser (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: Hugging Face Space ingest URL (no trailing slash required)
HF_INGEST_URL=https://YOUR_USERNAME-YOUR_SPACE.hf.space

# Shared secret: set the same value in the HF Space as INGEST_SECRET
INGEST_SECRET=generate_a_long_random_string

# Vercel: set Root Directory to `web` for this monorepo layout, then add the variables above.
